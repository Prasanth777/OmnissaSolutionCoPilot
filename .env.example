AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment
AZURE_OPENAI_VISION_DEPLOYMENT=your-vision-deployment-optional

# Best open-source default for this use case (English enterprise docs)
HF_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Optional
CHROMA_DIR=data/chroma
CHROMA_COLLECTION_NAME=omnissa_techzone
SITEMAP_RESOURCE_ONLY=1

# Optional optimization flags (disabled by default)
ENABLE_LLM_LINGUA=0
ENABLE_DSPY_OPTIMIZATION=0
